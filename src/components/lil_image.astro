---

interface Props {
  src?: string;
  alt?: string;
}
 
const { src, alt = '' } = Astro.props;
---
 
<div class="side-image">
  {src
    ? <img src={src} alt={alt} />
    : <div class="side-image__placeholder" />
  }
</div>
 <style>
 .side-image {
    justify-self: center;
    
    width: 80%;
  border-radius: 2rem;
  overflow: hidden;
  aspect-ratio: 1;
  background: #111;
}
 
.side-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
 
.side-image__placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, #1a2a4a, #0a0a1a);
}</style>