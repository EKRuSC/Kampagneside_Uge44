---

interface Props {
  src?: string;
  alt?: string;
  initial?: string;
}

const { src, alt = '', initial = 'E' } = Astro.props;
---

<div class="big">
  {src
    ? <img src={src} alt={alt} />
    : <div class="big__placeholder">{initial}</div>
  }
</div>

<style>
.big {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 2rem;
  overflow: hidden;
  margin-bottom: 3rem;
}
 
.big img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
 
.big__placeholder {
  width: 100%;
  height: 100%;
  background: #1e1e1e;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 5rem;
  font-weight: 600;
  color: var(--colour--beige);
  letter-spacing: .05em;
}
</style>